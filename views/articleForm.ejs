<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= article ? 'Edit Article' : 'New Article' %> - ManusBlog</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('navbar') %>
  
  <div class="container">
    <div class="card">
      <h1><%= article ? 'Edit Article' : 'Create New Article' %></h1>
      <form action="<%= article ? '/articles/update/' + article._id : '/articles' %>" method="POST">
        <div class="form-group">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" value="<%= article ? article.title : '' %>" required>
        </div>
        <div class="form-group">
          <label for="content">Content</label>
          <textarea id="content" name="content" required><%= article ? article.content : '' %></textarea>
        </div>
        <button type="submit" class="btn btn-primary"><%= article ? 'Update Article' : 'Publish Article' %></button>
        <a href="/articles" class="btn" style="background-color: #95a5a6; color: white;">Cancel</a>
      </form>
    </div>
  </div>
</body>
</html>
